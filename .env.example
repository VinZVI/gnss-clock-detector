# ============================================================
#  GNSS Clock Anomaly Detector — файл окружения
#
#  Скопируйте: cp .env.example .env
#  .env НЕ коммитится в git (защищён .gitignore)
# ============================================================

# ------------------------------------------------------------
# Источник данных
#   ftp   — только GLONASS-IAC FTP
#   nasa  — только NASA CDDIS HTTPS
#   auto  — сначала GLONASS-IAC, при неудаче NASA  ← рекомендуется
# ------------------------------------------------------------
GNSS_DATA_SOURCE=auto

# ------------------------------------------------------------
# NASA Earthdata Login
#   Регистрация: https://urs.earthdata.nasa.gov/users/new
#
# Способ 1 (рекомендуется на Windows): Bearer Token
#   — НЕ требует TLS-редиректов → решает ConnectionResetError 10054
#   — Получить токен вручную:
#       1. Войти на https://urs.earthdata.nasa.gov
#       2. Меню: Generate Token
#       3. Скопировать token и вставить ниже
#   — Или оставить пустым: клиент получит токен АВТОМАТИЧЕСКИ
#     через NASA EDL API (нужны USER + PASS)
# ------------------------------------------------------------
NASA_EARTHDATA_USER=your_earthdata_username
NASA_EARTHDATA_PASS=your_earthdata_password

# Bearer token (необязательно — заполняется автоматически или вручную)
# Действует 60 дней. Кешируется в .token_cache (не в git)
NASA_EARTHDATA_TOKEN=

# Продукт IGS:
#   igu — ultra-rapid (4×/день, задержка ~3ч)  ← рекомендуется
#   igr — rapid (1×/день, задержка ~17ч)
#   igs — final (1×/неделю, задержка ~10 дней)
NASA_PRODUCT=igu

# URL архива CDDIS (оставьте дефолт, если не знаете зачем менять)
# Примечание: cddis.nasa.gov мигрировал на earthdata.nasa.gov (июнь 2025)
# NASA_BASE_URL=https://cddis.nasa.gov/archive/gnss/products

# ------------------------------------------------------------
# FTP GLONASS-IAC (дефолты подходят для анонимного доступа)
# ------------------------------------------------------------
GNSS_FTP_HOST=ftp.glonass-iac.ru
GNSS_FTP_PORT=21
GNSS_FTP_USER=anonymous
GNSS_FTP_PASSWD=anonymous
GNSS_FTP_TIMEOUT=30
GNSS_FTP_BASE=/MCC/PRODUCTS
GNSS_FTP_SUBDIR=ultra
GNSS_PRODUCT_PREFIX=Stark

# ------------------------------------------------------------
# ETL настройки
# ------------------------------------------------------------
GNSS_ETL_DAYS_BACK=3        # загружать данные за N последних дней
GNSS_ETL_RETAIN_DAYS=14     # хранить данные в БД N дней
GNSS_MAD_THRESHOLD=3.0      # порог MAD-детекции аномалий

# ------------------------------------------------------------
# База данных SQLite
# ------------------------------------------------------------
GNSS_DB_PATH=./db.sqlite3

# ------------------------------------------------------------
# Flask
# ------------------------------------------------------------
FLASK_DEBUG=0                          # 1 для локальной разработки
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
SECRET_KEY=change-me-in-production     # замените на случайную строку!
